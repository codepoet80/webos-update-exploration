#!/bin/sh
# postinst — runs as ROOT via Preware / WebOS Quick Install (NOT palm-install).
# Installs the fingerprint helper + root status daemon into system space.
set -e

APP=/media/cryptofs/apps/usr/palm/applications/org.webosarchive.otaready

# root fs is normally rw on the TouchPad; remount defensively for /usr and /etc writes
mount -o rw,remount / 2>/dev/null || true

# fingerprint helper (read-only device inspection) + status daemon +
# direct-update helper (the daemon's install action shells out to it)
cp "$APP/device/ota-fingerprint" /usr/bin/ota-fingerprint
cp "$APP/device/otaready-daemon" /usr/bin/otaready-daemon
cp "$APP/device/direct-update.sh" /usr/bin/ota-direct-update
chmod 755 /usr/bin/ota-fingerprint /usr/bin/otaready-daemon /usr/bin/ota-direct-update

# upstart job so the daemon starts on boot
cp "$APP/device/otaready-daemon.conf" /etc/event.d/otaready-daemon
chmod 644 /etc/event.d/otaready-daemon

# status directory the app reads from (inside the app jail this maps to /media/internal)
mkdir -p /media/internal/.otaready

# --- JS command-bridge service registration (Luna/LS2) ---------------------
# The service dir itself ships in the app payload (data.tar.gz) at:
#   /media/cryptofs/apps/usr/palm/services/org.webosarchive.otaready.service
# but LS2 role + bus-name files live outside cryptofs and are NOT created by a
# plain `ipkg install`, so we drop them here (mirrors what the real installer does).
SVC=/media/cryptofs/apps/usr/palm/services/org.webosarchive.otaready.service
SVCID=org.webosarchive.otaready.service
if [ -d "$SVC/ls2" ]; then
    mkdir -p /var/palm/ls2/roles/prv /var/palm/ls2/roles/pub \
             /var/palm/ls2/services/prv /var/palm/ls2/services/pub
    FRESH=1; [ -f /var/palm/ls2/roles/pub/$SVCID.json ] && FRESH=0
    cp "$SVC/ls2/role.prv.json"        /var/palm/ls2/roles/prv/$SVCID.json
    cp "$SVC/ls2/role.pub.json"        /var/palm/ls2/roles/pub/$SVCID.json
    cp "$SVC/ls2/$SVCID.service"       /var/palm/ls2/services/prv/$SVCID
    cp "$SVC/ls2/$SVCID.service"       /var/palm/ls2/services/pub/$SVCID
    echo "  registered $SVCID on the Luna bus"
    [ "$FRESH" = 1 ] && echo "  NOTE: first install — REBOOT once so ls-hubd picks up the new service"
fi

# start now so the app has status without waiting for a reboot
start otaready-daemon 2>/dev/null || echo "otaready-daemon will start on next boot"

echo "otaready: installed helper + daemon + bridge service"
exit 0
