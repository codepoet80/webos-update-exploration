#!/bin/sh
# otaready-daemon — root helper for the "Get Ready for OTA" app.
#
# The jailed Enyo apps cannot read system state or write system files, so this root
# daemon does both and bridges through /media/internal/.otaready/ (visible in the jail):
#   - writes status.json  (fingerprint, for the Get-Ready app)      [Part 1]
#   - writes offer.json    (our server's offer, for System Updates)  [Part 2]
#   - honors commands dropped in `cmd`: check | redirect | revert | install
#
# Commands are triggered by the apps (via the otaready JS service, which can write cmd).

DIR=/media/internal/.otaready
STATUS="$DIR/status.json"
OFFER="$DIR/offer.json"
CMD="$DIR/cmd"
FP=/usr/bin/ota-fingerprint
DU=/usr/bin/ota-direct-update
LOG=/var/log/otaready-daemon.log
REFRESH_EVERY=15   # seconds
APP_APPINFO=/media/cryptofs/apps/usr/palm/applications/org.webosarchive.otaready/appinfo.json

# our update server (override by writing a URL into $DIR/server-url)
SERVER_DEFAULT="http://192.168.10.20:8080"

# System Updates app + our patched copy
SU_DIR=/usr/palm/applications/com.palm.app.updates
SU_JS="$SU_DIR/app/UpdatesApp.js"
SU_BAK="$SU_JS.otaready-orig"
SU_APPINFO="$SU_DIR/appinfo.json"
SU_APPINFO_BAK="$SU_APPINFO.otaready-orig"
PATCHED=/media/cryptofs/apps/usr/palm/applications/org.webosarchive.otaready/device/UpdatesApp.patched.js

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') otaready: $*" >> "$LOG" 2>&1; }
server_url() { [ -f "$DIR/server-url" ] && tr -d ' \t\r\n' < "$DIR/server-url" || echo "$SERVER_DEFAULT"; }

luna_restart() {
    # reload cached Enyo apps after swapping UpdatesApp.js
    log "restarting LunaSysMgr"
    killall LunaSysMgr 2>/dev/null || true   # upstart respawns it
}

refresh_status() {
    if /bin/sh "$FP" --json > "$STATUS.tmp" 2>/dev/null; then
        mv "$STATUS.tmp" "$STATUS"
    else
        rm -f "$STATUS.tmp"; log "fingerprint failed"
    fi
}

# Write server-state.json — the OTA Ready app's view of our relationship with the
# community server. Drives its three states:
#   redirected=false                -> state 1 (offer the "Use New Update Server" button)
#   redirected=true, contacted=false-> state 2 (re-pointed, no confirmed server check yet)
#   redirected=true, contacted=true -> state 3 (re-pointed + a recorded successful check)
# "redirected" is ground truth = the System Updates patch is applied (backup exists).
# "contacted" is sticky since the last re-point: once we get a good server response we
# remember it in .last-contact (cleared by apply_patch/revert_patch).
write_server_state() {
    live_ok="$1"; result="$2"
    [ -f "$SU_BAK" ] && redirected=true || redirected=false
    if [ "$live_ok" = true ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S')|$result" > "$DIR/.last-contact"
    fi
    if [ -f "$DIR/.last-contact" ]; then
        contacted=true
        lastTime=$(cut -d'|' -f1 < "$DIR/.last-contact")
        lastResult=$(cut -d'|' -f2 < "$DIR/.last-contact")
    else
        contacted=false; lastTime=""; lastResult=""
    fi
    printf '{"redirected":%s,"contacted":%s,"serverUrl":"%s","lastContact":"%s","lastResult":"%s"}\n' \
        "$redirected" "$contacted" "$(server_url)" "$lastTime" "$lastResult" > "$DIR/server-state.json"
}

# Produce offer.json (native UpdatesApp payload shape) AND record server-contact state.
# Always queries the live server (even when a test-offer override is serving the demo)
# so the OTA Ready app can tell whether we've actually reached our server.
make_offer() {
    baseline=$(grep -o '"verdict":"[A-Z]*"' "$STATUS" 2>/dev/null | head -1 | cut -d'"' -f4)
    [ -z "$baseline" ] && baseline=UNKNOWN
    url="$(server_url)/api/updates/plan?baseline=$baseline"
    resp=$(curl -s -m 15 "$url" 2>/dev/null)

    live_ok=false; result=""
    if echo "$resp" | grep -q '"status":"ok"'; then
        live_ok=true
        # Available iff the plan auto-delivers a package: non-empty  "deliver":[{...
        if echo "$resp" | grep -q '"deliver":\[[ ]*{'; then result=Available; else result=UpToDate; fi
    fi

    # Serve the offer System Updates reads: test override wins (demo), else live result.
    # offer_status is what System Updates will show — that's what the OTA Ready app
    # reports too, so the two screens stay consistent (even in demo mode).
    src=live
    if [ -f "$DIR/.installed" ]; then
        # this update cycle's payload was already delivered -> nothing more to offer
        printf '{"status":"UpToDate","networkAvailable":true}\n' > "$OFFER"
        offer_status=UpToDate; src="delivered"
    elif [ -f "$DIR/test-offer.json" ]; then
        cp "$DIR/test-offer.json" "$OFFER"
        offer_status=$(grep -o '"status":"[^"]*"' "$DIR/test-offer.json" | head -1 | cut -d'"' -f4)
        [ -z "$offer_status" ] && offer_status="$result"
        src="demo"
    elif [ "$result" = Available ]; then
        ver=$(echo "$resp" | grep -o '"title":"[^"]*"' | head -1 | cut -d'"' -f4)
        [ -z "$ver" ] && ver="webOS Community Update"
        printf '{"status":"Available","version":"%s","size":"5","installTime":"5","networkAvailable":true,"priority":"optional"}\n' "$ver" > "$OFFER"
        offer_status=Available
    else
        printf '{"status":"UpToDate","networkAvailable":true}\n' > "$OFFER"
        offer_status=UpToDate
    fi

    # log only when the served offer changes (avoids one line per 15s poll)
    if [ "$offer_status|$src|$live_ok" != "$_last_offer" ]; then
        log "offer: $offer_status [$src] (baseline=$baseline, server contacted=$live_ok)"
        _last_offer="$offer_status|$src|$live_ok"
    fi

    write_server_state "$live_ok" "$offer_status"
}

# Bump com.palm.app.updates' appinfo version by +1 on the last dotted field.
# REQUIRED after swapping UpdatesApp.js: webOS serves cached app code, so a plain
# Luna restart re-runs the OLD bytecode unless the version changes (hard-won
# lesson #1). Incrementing every apply guarantees the patched code is loaded.
bump_su_version() {
    cur=$(sed -n 's/.*"version"[ ]*:[ ]*"\([0-9.]*\)".*/\1/p' "$SU_APPINFO" | head -1)
    if [ -z "$cur" ]; then log "bump: could not read version from $SU_APPINFO"; return 1; fi
    major=$(echo "$cur" | cut -d. -f1)
    minor=$(echo "$cur" | cut -d. -f2); [ -z "$minor" ] && minor=0
    patch=$(echo "$cur" | cut -d. -f3); [ -z "$patch" ] && patch=0
    new="$major.$minor.$((patch + 1))"
    tmp="$SU_APPINFO.otaready-tmp"
    if sed 's/"version"[ ]*:[ ]*"[0-9.]*"/"version": "'"$new"'"/' "$SU_APPINFO" > "$tmp" && cp "$tmp" "$SU_APPINFO"; then
        rm -f "$tmp"; log "bumped com.palm.app.updates version $cur -> $new (cache-bust)"
    else
        rm -f "$tmp"; log "bump: failed to rewrite $SU_APPINFO"; return 1
    fi
}

apply_patch() {   # redirect: make System Updates use our server
    if [ ! -f "$PATCHED" ]; then log "patched UpdatesApp.js missing at $PATCHED"; return 1; fi
    mount -o rw,remount / 2>/dev/null || true
    [ -f "$SU_BAK" ] || cp -p "$SU_JS" "$SU_BAK"                 # save stock JS once
    [ -f "$SU_APPINFO_BAK" ] || cp -p "$SU_APPINFO" "$SU_APPINFO_BAK"  # save stock appinfo once
    cp "$PATCHED" "$SU_JS"
    chmod 644 "$SU_JS"
    bump_su_version                                             # force Luna to drop cached UpdatesApp.js
    echo '{"status":"applied"}' > "$DIR/redirect-result.json"
    rm -f "$DIR/.last-contact" "$DIR/.installed"                 # fresh re-point -> state 2, offers re-enabled
    write_server_state false ""
    log "applied UpdatesApp.js reroute (backup: $SU_BAK)"
    sleep 2                                                     # let the app show its "screen will reload" notice
    luna_restart
}

revert_patch() {  # revert: restore the stock System Updates app (JS + version)
    mount -o rw,remount / 2>/dev/null || true
    if [ -f "$SU_BAK" ]; then
        cp -p "$SU_BAK" "$SU_JS"; rm -f "$SU_BAK"
        [ -f "$SU_APPINFO_BAK" ] && { cp -p "$SU_APPINFO_BAK" "$SU_APPINFO"; rm -f "$SU_APPINFO_BAK"; }
        echo '{"status":"reverted"}' > "$DIR/redirect-result.json"
        rm -f "$DIR/.last-contact" "$DIR/.installed"            # back to state 1, offers re-enabled
        write_server_state false ""
        log "reverted UpdatesApp.js + appinfo"
        luna_restart
    else
        log "no backup to revert"
    fi
}

# install: the direct-update flow (download IPKs from our server -> write
# /var/lib/software/SessionFiles -> make-update-uimage -> reboot into the OTA
# ramdisk). Progress is reported in install-status.json, which the patched
# System Updates app polls.
#
# SAFETY: the download+session-file prep is non-destructive and reversible. The
# irreversible step (build uimage + reboot into the updater) only runs if
# $DIR/arm-install exists. Without that flag the daemon preps and stops, so the
# handoff can be exercised on a test device without any risk of a reboot/flash.
# mark this update cycle's payload as delivered: subsequent offers resolve to
# UpToDate (System Updates shows "no more updates", OTA Ready shows up to date).
mark_installed() {
    touch "$DIR/.installed"
    printf '{"status":"UpToDate","networkAvailable":true}\n' > "$OFFER"
}

do_install() {
    echo '{"status":"preparing"}' > "$DIR/install-status.json"
    log "install: preparing (direct-update)"
    url="$(server_url)"

    if [ ! -x "$DU" ]; then
        echo '{"status":"failed","reason":"direct-update helper missing"}' > "$DIR/install-status.json"
        log "install: $DU missing"; return 1
    fi

    # download packages + build SessionFiles (non-destructive). -y = non-interactive.
    if "$DU" "$url" -y >> "$LOG" 2>&1; then
        if [ -s /var/lib/software/SessionFiles/update_list.txt ]; then
            log "install: session files prepared"
        else
            echo '{"status":"uptodate","note":"server offered no packages"}' > "$DIR/install-status.json"
            log "install: server offered no packages — nothing to install"
            return 0
        fi
    else
        echo '{"status":"failed","reason":"prepare failed"}' > "$DIR/install-status.json"
        log "install: prepare failed"; return 1
    fi

    if [ -f "$DIR/arm-install" ]; then
        echo '{"status":"installing"}' > "$DIR/install-status.json"
        log "install: ARMED — building uimage and rebooting into the OTA ramdisk"
        if /usr/share/ota-scripts/make-update-uimage >> "$LOG" 2>&1; then
            mark_installed; sync; reboot
        else
            echo '{"status":"failed","reason":"make-update-uimage failed"}' > "$DIR/install-status.json"
            log "install: make-update-uimage failed"
        fi
    else
        mark_installed   # payload delivered (staged); flip the offer to UpToDate
        echo '{"status":"prepared","note":"not armed; create .otaready/arm-install to flash+reboot"}' > "$DIR/install-status.json"
        log "install: prepared but NOT armed ($DIR/arm-install absent) — skipping reboot"
    fi
}

# Diagnostic report the "Send Device Details" menu item emails to the curator.
# Regenerated each refresh so it's always current; the app just reads the file.
write_diagnostics() {
    appver=$(sed -n 's/.*"version"[ ]*:[ ]*"\([0-9.]*\)".*/\1/p' "$APP_APPINFO" 2>/dev/null | head -1)
    {
        echo "webOS Archive — OTA Ready (Beta) diagnostic report"
        echo "Generated: $(date '+%Y-%m-%d %H:%M:%S')"
        echo "App version: ${appver:-unknown}"
        echo "webOS build: $(grep '^BUILDNAME=' /etc/palm-build-info 2>/dev/null | cut -d= -f2)"
        echo "Uptime (s): $(cut -d. -f1 /proc/uptime 2>/dev/null)"
        echo "Free space: $(df -k /media/internal 2>/dev/null | awk 'END{printf "%d MB free of %d MB\n", $4/1024, $2/1024}')"
        echo
        echo "--- fingerprint (status.json) ---"
        cat "$STATUS" 2>/dev/null
        echo; echo
        echo "--- update-server state (server-state.json) ---"
        cat "$DIR/server-state.json" 2>/dev/null
        echo; echo
        echo "--- recent daemon log ---"
        tail -20 "$LOG" 2>/dev/null
    } > "$DIR/diagnostics.txt.tmp" 2>/dev/null && mv "$DIR/diagnostics.txt.tmp" "$DIR/diagnostics.txt"
}

mkdir -p "$DIR"
log "started (pid $$)"
refresh_status
make_offer
write_diagnostics
count=0
while true; do
    if [ -f "$CMD" ]; then
        c=$(tr -d ' \t\r\n' < "$CMD" 2>/dev/null); rm -f "$CMD"
        case "$c" in
            check)      log "cmd: check";      refresh_status; make_offer; write_diagnostics ;;
            redirect)   log "cmd: redirect";   apply_patch ;;
            revert)     log "cmd: revert";     revert_patch ;;
            install)    log "cmd: install";    do_install ;;
            reset)      log "cmd: reset-test"; rm -f "$DIR/.installed" "$DIR/install-status.json"; make_offer; write_diagnostics ;;
            "")         : ;;
            *)          log "cmd: unknown ($c)" ;;
        esac
    fi
    count=$((count + 1))
    if [ "$count" -ge "$REFRESH_EVERY" ]; then refresh_status; make_offer; write_diagnostics; count=0; fi
    sleep 1
done
